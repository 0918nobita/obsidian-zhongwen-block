{
    "name": "@0918nobita/obsidian-zhongwen-block",
    "version": "0.6.0",
    "description": "An Obsidian plugin which provides code blocks with features for Chinese learners",
    "private": "true",
    "type": "module",
    "workspaces": [
        "code-block-processor"
    ],
    "scripts": {
        "build": "vite build",
        "lint": "eslint .",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "memlab": "memlab run --scenario ./scenario.cjs --work-dir ./memlab"
    },
    "devDependencies": {
        "@types/node": "20.11.24",
        "@vanilla-extract/vite-plugin": "4.0.4",
        "eslint": "8.57.0",
        "globals": "14.0.0",
        "memlab": "1.1.45",
        "obsidian": "1.5.7-1",
        "prettier": "3.2.5",
        "typescript": "5.3.3",
        "typescript-eslint": "7.1.0",
        "vite": "5.1.4"
    },
    "dependencies": {
        "@vanilla-extract/css": "1.14.1",
        "zod": "3.22.4"
    },
    "prettier": {
        "semi": true,
        "singleQuote": true
    }
}
